# =============================================================================
# LLM（OpenAI 兼容接口）
# value：填实际字符串，不要留空格除非服务商要求。
# =============================================================================

# 模型标识，格式依中转商文档而定（如 openai/xxx 或裸模型名）。
MODEL=

# API 密钥，在服务商控制台生成后粘贴。
OPENAI_API_KEY=

# OpenAI 兼容 API 的 Base URL，须带协议且一般以 /v1 结尾（以服务商文档为准）。
OPENAI_BASE_URL=

# =============================================================================
# CrewAI / 可观测性 / LiteLLM（布尔：仅填 true 或 false，大小写一般均可）
# =============================================================================

# true：启用 CrewAI Tracing，运行链路上报到 CrewAI tracing。
# false：关闭 Tracing，不上报（本地开发常用）。
CREWAI_TRACING_ENABLED=

# true：关闭 CrewAI 内置遥测（推荐本地或内网）。
# false：允许内置遥测上报。
CREWAI_DISABLE_TELEMETRY=

# true：声明退出遥测（与 CREWAI_DISABLE_TELEMETRY 类似，兼容旧变量名）。
# false：不声明退出（仍受其它遥测开关影响）。
CREWAI_TELEMETRY_OPT_OUT=

# true：禁用 OpenTelemetry SDK，关闭 OTel 相关采集。
# false：允许 OTel SDK 按默认行为工作。
OTEL_SDK_DISABLED=

# true：让 LiteLLM 使用本地模型价格表，避免启动时拉取远程价格配置。
# false：不按上述方式强制本地价格表（行为以 LiteLLM 版本为准）。
LITELLM_LOCAL_MODEL_COST_MAP=

# LiteLLM 日志级别；常用 DEBUG（最细）、INFO、WARNING。取消下行注释并填写。
# LITELLM_LOG=

# OpenAI Python SDK 调试日志；例如 debug 可打印 HTTP 细节。取消下行注释并填写。
# OPENAI_LOG=
