# MODEL=openai/deepseek-ai/DeepSeek-V4-Flash
# OPENAI_API_KEY=sk-vjxmeybwpvtpmxxpairurpkwxkfmdqkmaksmtjhswypfmpxb
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1

MODEL=gemini-3.1-pro-preview
OPENAI_API_KEY=sk-
OPENAI_BASE_URL=https://api.viviai.cc/v1

# 是否启用 CrewAI Tracing（true 会将运行链路上报到 CrewAI tracing 系统）
CREWAI_TRACING_ENABLED=false
# 关闭 CrewAI 内置遥测（推荐在本地开发或内网环境开启 true）
CREWAI_DISABLE_TELEMETRY=true
# 旧版/兼容写法的遥测关闭开关（与上面的 DISABLE_TELEMETRY 作用相近）
CREWAI_TELEMETRY_OPT_OUT=true
# 关闭 OpenTelemetry SDK（会同时禁用 OTel 相关采集）
OTEL_SDK_DISABLED=true
# 强制 LiteLLM 使用本地模型价格表，避免启动时拉取远程价格配置
LITELLM_LOCAL_MODEL_COST_MAP=True
# LiteLLM 日志级别（DEBUG 最详细，排障常用；可改为 INFO/WARNING）
# LITELLM_LOG=DEBUG
# OpenAI Python SDK 调试日志开关（可打印 HTTP 请求细节）
# OPENAI_LOG=debug