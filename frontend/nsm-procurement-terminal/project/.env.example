# -----------------------------------------------------------------------------
# Supabase（Vite 前端）
# -----------------------------------------------------------------------------
# 1. 在 Supabase 控制台打开你的项目：Project Settings → API。
# 2. 将下方两项复制到本目录的 `.env.local`（勿提交仓库），并把占位符换成真实值。
# 3. 仅 `VITE_` 前缀的变量会注入到浏览器端代码；不要用 service_role 密钥。
#
# - Project URL        → VITE_SUPABASE_URL（形如 https://xxxx.supabase.co）
# - anon / public key  → VITE_SUPABASE_ANON_KEY（JWT 形式的长字符串）
# -----------------------------------------------------------------------------

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
